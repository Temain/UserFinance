# Общие настройки Postgres для docker-compose и локального запуска.
POSTGRES_HOST=localhost
POSTGRES_DB=user_finance
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
JWT_ISSUER=UserFinance
JWT_AUDIENCE=UserFinance.Client
JWT_SIGNING_KEY=super-secret-development-signing-key-12345
JWT_EXPIRES_IN_MINUTES=60
USER_SERVICE_PORT=8081
USER_SERVICE_URL=http://localhost:8081
USER_SERVICE_CURRENCIES_PATH=/api/users/{userId}/currencies
FINANCE_SERVICE_PORT=8082
CBR_DAILY_RATES_URL=https://www.cbr.ru/scripts/XML_daily.asp
CURRENCY_UPDATER_INTERVAL_MINUTES=60
